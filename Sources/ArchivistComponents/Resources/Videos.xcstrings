      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When on, each played video is downloaded in the background so you can seek instantly once the download finishes. Cached files are kept for 24 hours."
          }
        }
      }
    },
